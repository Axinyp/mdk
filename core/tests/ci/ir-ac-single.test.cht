// [正向] 单 IR 设备空调动态温度控制
// 测试点: IR 设备声明、SEND_IRCODE、if-else 温度链、禁止 IRCODE<> 拼接
DEFINE_DEVICE
    TR1_IR1 = L:2:IR;
    tp = T:10:TP;

DEFINE_COMBINE

DEFINE_CONSTANT

DEFINE_VARIABLE
    int curTemp = 25;

DEFINE_FUNCTION
    void SendAcTemp(int temp)
    {
        if (temp == 16) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:16_1">); }
        else if (temp == 17) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:17_1">); }
        else if (temp == 18) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:18_1">); }
        else if (temp == 19) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:19_1">); }
        else if (temp == 20) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:20_1">); }
        else if (temp == 21) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:21_1">); }
        else if (temp == 22) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:22_1">); }
        else if (temp == 23) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:23_1">); }
        else if (temp == 24) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:24_1">); }
        else if (temp == 25) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:25_1">); }
        else if (temp == 26) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:26_1">); }
        else if (temp == 27) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:27_1">); }
        else if (temp == 28) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:28_1">); }
        else if (temp == 29) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:29_1">); }
        else if (temp == 30) { SEND_IRCODE(TR1_IR1, 1, IRCODE<"UserIRDB:room:brand:model:ts:30_1">); }
        SEND_TEXT(tp, 300, ITOA(temp));
    }

DEFINE_TIMER

DEFINE_START

DEFINE_EVENT
    BUTTON_EVENT(tp, 301)
    {
        PUSH()
        {
            if (curTemp < 30)
            {
                curTemp = curTemp + 1;
                SendAcTemp(curTemp);
            }
        }
    }
    BUTTON_EVENT(tp, 302)
    {
        PUSH()
        {
            if (curTemp > 16)
            {
                curTemp = curTemp - 1;
                SendAcTemp(curTemp);
            }
        }
    }

DEFINE_PROGRAME
