// [正向] 单触屏工程 DEFINE_COMBINE 必须留空
// 测试点: 单个 TP 设备时 DEFINE_COMBINE 为空，不填任何设备名
DEFINE_DEVICE
    tp = T:10:TP;

DEFINE_COMBINE

DEFINE_CONSTANT

DEFINE_VARIABLE
    int state = 0;

DEFINE_FUNCTION

DEFINE_TIMER

DEFINE_START

DEFINE_EVENT
    BUTTON_EVENT(tp, 1)
    {
        PUSH()
        {
            state = 1;
        }
    }

DEFINE_PROGRAME
